set_global_assignment -name FAMILY "Cyclone V"
set_global_assignment -name DEVICE 5CSEBA6U23I7
set_global_assignment -name TOP_LEVEL_ENTITY De10PlatformTop

set_global_assignment -name VERILOG_FILE ../rtl/De10Top.v
set_global_assignment -name VERILOG_FILE De10PlatformTop.v
# Compile the Qsys top wrappers into the default project library so plain
# Verilog instantiations in De10PlatformTop bind to the real module views.
set_global_assignment -name QIP_FILE ../qsys/generated/pll/synthesis/de10_core_pll.qip
set_global_assignment -name QIP_FILE ../qsys/generated/synthesis/de10_soc.qip
set_global_assignment -name VERILOG_FILE ../qsys/generated/pll/synthesis/de10_core_pll.v
set_global_assignment -name VERILOG_FILE ../qsys/generated/synthesis/de10_soc.v
set_global_assignment -name SDC_FILE SpinalVoodoo_de10.sdc

set_global_assignment -name RESERVE_ALL_UNUSED_PINS "AS INPUT TRI-STATED"
set_global_assignment -name NUM_PARALLEL_PROCESSORS ALL
set_global_assignment -name AUTO_DSP_RECOGNITION ON
set_global_assignment -name ROUTER_TIMING_OPTIMIZATION_LEVEL MINIMUM

# Board clock/reset pin wiring.
# NOTE: These are DE10-Nano oriented defaults and can be overridden if your
# carrier/wiring differs.
set_location_assignment PIN_V11 -to clk
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to clk

# Exact DE10-Nano HPS DDR3 pin locations.
set_location_assignment PIN_C28 -to hps_memory_mem_a[0]
set_location_assignment PIN_B28 -to hps_memory_mem_a[1]
